{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".github/hooks/pre-tool-use.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook copilot",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".github/hooks/post-tool-use.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".github/hooks/stop.sh"
          }
        ]
      }
    ]
  }
}

