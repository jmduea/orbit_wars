{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": ".cursor/hooks/cursor-pre-tool-use.sh"
      }
    ],
    "postToolUse": [
      {
        "command": ".cursor/hooks/cursor-post-tool-use.sh"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/cursor-stop.sh",
        "loop_limit": 1
      }
    ]
  }
}
