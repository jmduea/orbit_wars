{
    "editor.formatOnSave": true,
    "files.autoSave": "onFocusChange",
    "python.terminal.activateEnvInCurrentTerminal": true,
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "[python]": {
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        },
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "pythonTestExplorer.testFramework": "pytest",
    "python.testing.pytestEnabled": true,
    "python.testing.pytestArgs": [
        "-m",
        "not slow and not jax"
    ],
    "chat.mcp.serverSampling": {
        "orbit_wars/.vscode/mcp.json: omg-workflow": {
            "allowedModels": [
                "copilot/auto",
                "copilotcli/auto",
                "claude-code/claude-haiku-4.5",
                "copilot/claude-haiku-4.5",
                "copilotcli/claude-haiku-4.5",
                "claude-code/claude-opus-4.7",
                "copilot/claude-opus-4.7",
                "copilotcli/claude-opus-4.7",
                "claude-code/claude-sonnet-4.5",
                "copilot/claude-sonnet-4.5",
                "copilotcli/claude-sonnet-4.5",
                "claude-code/claude-sonnet-4.6",
                "copilot/claude-sonnet-4.6",
                "copilotcli/claude-sonnet-4.6",
                "copilot/gemini-2.5-pro",
                "copilot/gemini-3-flash-preview",
                "copilot/gemini-3.1-pro-preview",
                "copilot/gemini-3.5-flash",
                "copilot/gpt-4.1",
                "copilotcli/gpt-4.1",
                "copilot/gpt-4o",
                "copilotcli/gpt-4o",
                "copilot/gpt-5-mini",
                "copilotcli/gpt-5-mini",
                "copilot/gpt-5.2",
                "copilotcli/gpt-5.2",
                "copilot/gpt-5.2-codex",
                "copilotcli/gpt-5.2-codex",
                "copilot/gpt-5.3-codex",
                "copilotcli/gpt-5.3-codex",
                "copilot/gpt-5.4",
                "copilotcli/gpt-5.4",
                "copilot/gpt-5.4-mini",
                "copilotcli/gpt-5.4-mini",
                "copilot/gpt-5.5",
                "copilotcli/gpt-5.5",
                "copilot/oswe-vscode-prime"
            ]
        }
    },
    "search.useIgnoreFiles": false,
    "search.experimental.useIgnoreFilesInFindFiles": true
}